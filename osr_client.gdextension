[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.3"

[libraries]
linux.debug.x86_64 = "res://bin/libosr-client.so"
linux.release.x86_64 = "res://bin/libosr-client.so"
windows.debug.x86_64 = "res://bin/libosr-client.dll"
windows.release.x86_64 = "res://bin/libosr-client.dll"
macos.debug.arm64 = "res://bin/libosr-client.dylib"
macos.release.arm64 = "res://bin/libosr-client.dylib"
